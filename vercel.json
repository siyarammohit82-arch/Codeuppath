{
  "version": 2,
  "buildCommand": "VERCEL=1 vite build && node script/build-api.mjs",
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/sitemap.xml", "dest": "/api/index.js" },
    { "src": "/robots.txt", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
